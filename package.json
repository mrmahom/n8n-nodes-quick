{
  "name": "n8n-nodes-quick",
  "version": "0.1.2",
  "description": "n8n community node + szabad API-kliens a QUiCK (helloquick.riport.app) számlázó/könyvelő rendszerhez",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "quick",
    "helloquick",
    "riport",
    "invoicing",
    "accounting",
    "hungary",
    "api-client"
  ],
  "license": "MIT",
  "homepage": "https://helloquick.riport.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrmahom/n8n-nodes-quick.git"
  },
  "engines": {
    "node": ">=20.15.0"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist/client",
    "dist/credentials",
    "dist/nodes",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.js.map"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/QuickApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Quick/Quick.node.js",
      "dist/nodes/Quick/QuickTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "ts-jest": "^29.1.5",
    "typescript": "^5.5.3",
    "undici": "^6.25.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "author": {
    "name": "E. Martin Maho",
    "email": "martin@maho.hu"
  }
}
